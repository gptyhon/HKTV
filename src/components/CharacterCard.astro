---
interface Props {
  name: string;
  points: number[];
  desc: string;
  image?: string;
}

const { name, points, desc, image } = Astro.props;

const DIM_NAMES = ["\u653B\u575A\u7EC8\u7ED3", "\u8FC7\u6E21\u5E73\u6ED1\u5EA6", "\u8D44\u6E90\u8F6C\u5316", "\u4F53\u7CFB\u7F81\u7ECA", "\u5C40\u5185\u5F71\u54CD"];
const DIM_EN = ["ASSAULT", "TRANSITION", "CONVERSION", "SYNERGY", "IMPACT"];
const BASE_MAX = [90, 80, 1.5, 80, 1.3];
const MIN_SCORES = [40, 40, 0.7, 40, 0.6];

const ratingRaw = points[5] ?? 0;
const ratingMin = 0.8;
const ratingMax = 1.3;
const ratingPercent = Math.min(100, Math.max(0, ((ratingRaw - ratingMin) / (ratingMax - ratingMin)) * 100));
const ratingDisplay = ratingRaw.toFixed(2);

function getGrade(pct: number) {
  if (pct >= 66) return { label: "GOOD", color: "#4ade80" };
  if (pct >= 33) return { label: "OKAY", color: "#facc15" };
  return { label: "LOW", color: "#ef4444" };
}

const ratingGrade = getGrade(ratingPercent);

const stats = DIM_NAMES.map((dimName, i) => {
  const value = points[i];
  const pct = Math.min(100, Math.max(0, ((value - MIN_SCORES[i]) / (BASE_MAX[i] - MIN_SCORES[i])) * 100));
  const rounded = Math.round(pct);
  return { name: dimName, nameEn: DIM_EN[i], value, pct: rounded, grade: getGrade(rounded) };
});

const R = 58;
const CX = 75;
const CY = 68;
const circumference = Math.PI * R;
const fillLen = (ratingPercent / 100) * circumference;
---

<div class="card">
  <div class="card-inner">
    <div class="card-left">
      <div class="card-left-bg"></div>
      <div class="portrait-area">
        {image ? (
          <img src={image} alt={name} class="portrait-img" />
        ) : (
          <div class="portrait-placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="rgba(255,255,255,0.08)">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          </div>
        )}
      </div>
      <div class="info-overlay">
        <h2 class="char-name">{name}</h2>
        <p class="char-desc">{desc}</p>
      </div>
      <div class="left-accent"></div>
    </div>

    <div class="card-right">
      <div class="rating-zone">
        <div class="side-rating">
          <span class="side-rating-value">-</span>
          <span class="side-rating-label">\u6682\u5B9A1</span>
        </div>
        <div class="gauge-wrapper">
          <div class="gauge-label-top">
            <span class="gauge-grade" style={`color: ${ratingGrade.color}`}>{ratingGrade.label}</span>
          </div>
          <svg class="gauge-svg" width="150" height="82" viewBox="0 0 150 82">
            <path d={`M ${CX - R} ${CY} A ${R} ${R} 0 0 1 ${CX + R} ${CY}`}
                  fill="none" stroke="#1e293b" stroke-width="8" />
            <path d={`M ${CX - R} ${CY} A ${R} ${R} 0 0 1 ${CX + R} ${CY}`}
                  fill="none" stroke={ratingGrade.color} stroke-width="8"
                  stroke-dasharray={`${fillLen} ${circumference}`}
                  stroke-linecap="round"
                  style="filter: drop-shadow(0 0 6px currentColor);" />
          </svg>
          <div class="gauge-center">
            <span class="gauge-value">{ratingDisplay}</span>
            <span class="gauge-sub">RATING</span>
          </div>
        </div>
        <div class="side-rating">
          <span class="side-rating-value">-</span>
          <span class="side-rating-label">\u6682\u5B9A2</span>
        </div>
      </div>

      <div class="divider"></div>

      <div class="stats-grid">
        {stats.map((stat) => (
          <div class="stat-cell">
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.nameEn}</div>
            <div class="bar-wrapper">
              <div class="bar-track">
                <div class="bar-fill" style={`width: ${stat.pct}%; background: ${stat.grade.color};`}></div>
                <div class="bar-indicator" style={`left: ${stat.pct}%;`}></div>
              </div>
              <span class="bar-grade" style={`color: ${stat.grade.color}`}>{stat.grade.label}</span>
            </div>
          </div>
        ))}
        <div class="stat-cell">
          <div class="stat-value">{ratingDisplay}</div>
          <div class="stat-label">OVERALL</div>
          <div class="bar-wrapper">
            <div class="bar-track">
              <div class="bar-fill" style={`width: ${Math.round(ratingPercent)}%; background: ${ratingGrade.color};`}></div>
              <div class="bar-indicator" style={`left: ${Math.round(ratingPercent)}%;`}></div>
            </div>
            <span class="bar-grade" style={`color: ${ratingGrade.color}`}>{ratingGrade.label}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    --bg-base: #1a2332; --bg-darker: #0e1520;
    --text-primary: #e2e8f0; --text-secondary: #94a3b8;
    --text-dim: #475569; --border: #253040;
    font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
    width: 820px; border-radius: 6px; overflow: hidden;
    background: var(--bg-base); box-shadow: 0 4px 24px rgba(0,0,0,0.5);
  }
  .card-inner { display: flex; min-height: 340px; }
  .card-left { position: relative; width: 250px; flex-shrink: 0; overflow: hidden; background: var(--bg-darker); }
  .card-left-bg { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(10,18,28,0.95) 100%); z-index: 1; }
  .left-accent { position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, #4ade80, #22d3ee); z-index: 3; }
  .portrait-area { position: relative; z-index: 0; display: flex; align-items: center; justify-content: center; height: 100%; padding: 20px; }
  .portrait-img { width: 100%; height: 280px; object-fit: contain; filter: drop-shadow(0 0 12px rgba(74,222,128,0.2)); }
  .portrait-placeholder { width: 100%; height: 280px; display: flex; align-items: center; justify-content: center; background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%); border-radius: 4px; }
  .info-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 16px 16px; z-index: 2; }
  .char-name { font-size: 22px; font-weight: 800; color: #fff; margin: 0 0 4px; line-height: 1.2; }
  .char-desc { font-size: 12px; color: var(--text-secondary); margin: 0; line-height: 1.4; }
  .card-right { flex: 1; display: flex; flex-direction: column; background: var(--bg-base); }
  .rating-zone { display: flex; align-items: center; justify-content: center; padding: 20px 24px 8px; gap: 16px; }
  .side-rating { display: flex; flex-direction: column; align-items: center; min-width: 80px; }
  .side-rating-value { font-size: 26px; font-weight: 700; color: var(--text-primary); line-height: 1; }
  .side-rating-label { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 4px; }
  .gauge-wrapper { position: relative; display: flex; flex-direction: column; align-items: center; }
  .gauge-label-top { margin-bottom: -4px; text-align: center; }
  .gauge-grade { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }
  .gauge-svg { display: block; }
  .gauge-center { position: absolute; bottom: 6px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; }
  .gauge-value { font-size: 36px; font-weight: 800; color: #fff; line-height: 1; letter-spacing: -0.02em; }
  .gauge-sub { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.15em; margin-top: 2px; }
  .divider { height: 1px; margin: 4px 20px 0; background: var(--border); }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); flex: 1; }
  .stat-cell { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 14px 12px 12px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); }
  .stat-cell:nth-child(3n) { border-right: none; }
  .stat-cell:nth-child(n+4) { border-bottom: none; }
  .stat-value { font-size: 28px; font-weight: 700; color: var(--text-primary); line-height: 1; margin-bottom: 4px; }
  .stat-label { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
  .bar-wrapper { display: flex; align-items: center; gap: 8px; width: 100%; max-width: 160px; }
  .bar-track { flex: 1; height: 4px; background: #2a3340; border-radius: 2px; position: relative; }
  .bar-fill { height: 100%; border-radius: 2px; }
  .bar-indicator { position: absolute; top: -4px; width: 2px; height: 12px; background: #fff; border-radius: 1px; transform: translateX(-50%); box-shadow: 0 0 4px rgba(255,255,255,0.4); }
  .bar-grade { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; flex-shrink: 0; }
</style>
